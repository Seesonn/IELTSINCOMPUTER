# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ieltsprep

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Scoring — Ollama (local free AI) or OpenAI fallback
# Ollama: https://ollama.com — pull model with: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# OpenAI (optional fallback if Ollama is unavailable)
OPENAI_API_KEY=your-openai-api-key

# eSewa Payment
ESEWA_MERCHANT_CODE=your-esewa-merchant-code
ESEWA_SECRET_KEY=your-esewa-secret-key
ESEWA_BASE_URL=https://rc-epay.esewa.com.np

# Khalti Payment
KHALTI_SECRET_KEY=your-khalti-secret-key
KHALTI_BASE_URL=https://a.khalti.com/api/v2

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Cloudinary (for screenshot uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth
# Get these from https://console.cloud.google.com -> APIs & Services -> Credentials -> Create OAuth 2.0 Client ID
# IMPORTANT: Add EVERY URL your frontend runs on to "Authorized JavaScript origins":
#   - http://localhost:5173 (local dev)
#   - https://your-dev-tunnel.inc1.devtunnels.ms (VS Code dev tunnel)
#   - https://your-production-domain.com (production)
# If you get "Error 400: origin_mismatch", the current frontend URL is missing from Authorized JavaScript origins.
# Set Authorized redirect URIs to (for server-side flow, not used by frontend implicit flow):
#   - http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
APP_NAME=IELTSPrep
APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DEBUG=true

# Additional CORS origins (comma or space separated) — add dev tunnel or production URLs here
# CORS_ORIGINS=https://zq9vj6vz-5173.inc1.devtunnels.ms,https://your-app.com
